# =========================
# Backend (FastAPI)
# =========================
APP_NAME=KOSPI Swing Signal API
API_PREFIX=/api

# SQLite default for local MVP
DATABASE_URL=sqlite:///./app.db

# mock | kis
MARKET_DATA_PROVIDER=mock
DEFAULT_SYMBOLS=005930,000660,035420,051910,068270
MOCK_TICK_INTERVAL_SECONDS=1.0
MOCK_PRICE_VOLATILITY=0.012
CANDLE_SECONDS=60
MAX_CANDLES_PER_SYMBOL=240
VOLUME_LOOKBACK=20
SUPPORT_RESISTANCE_LOOKBACK=20
WEBSOCKET_PING_SECONDS=15

# Optional broker adapter placeholders
KIS_APP_KEY=
KIS_APP_SECRET=
# 실서버 예시: https://openapi.koreainvestment.com:9443
# 모의서버 예시: https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_POLL_INTERVAL_SECONDS=1.0
KIS_REQUEST_TIMEOUT_SECONDS=10
KIS_HISTORY_SEED_LIMIT=240
KIS_HISTORY_BACKFILL_CHUNKS=3
KIS_MARKET_DIV_CODE=J
KIS_QUOTE_TR_ID=FHKST01010100
KIS_INTRADAY_TR_ID=FHKST03010200

# Optional telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =========================
# Frontend (Next.js)
# =========================
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_WS_URL=
